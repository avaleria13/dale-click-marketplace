<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pedidos | Dale Click</title>
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/partials/sidebar.css" />
  <link rel="stylesheet" href="/css/partials/topbar.css" />
  <link rel="stylesheet" href="/css/pedidos.css" />
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar', { activePage: 'pedidos' }) %>

    <main class="contenido">
      <!-- <%- include('../partials/topbar', { usuario }) %> -->
      <%- include('../partials/topbar') %>

      <section class="seccion-pedidos">
        <div class="barra-filtros-pedidos">
          <div class="campo-busqueda-pedido">
            <input
              type="text"
              id="busquedaPedido"
              placeholder="Buscar pedido por ID, nombre o apellido..."
            />
            <button type="button" class="boton-busqueda-pedido" aria-label="Buscar pedido">
              <img src="/images/buscar.png" alt="Buscar" />
            </button>
          </div>

          <select id="filtroProductoPedido" class="select-filtro-pedido">
            <option value="">Productos</option>
            <% (productos || []).forEach((producto) => { %>
              <option value="<%= producto.productName %>"><%= producto.productName %></option>
            <% }) %>
          </select>

          <select id="filtroEstadoPedido" class="select-filtro-pedido">
            <option value="">Estado</option>
            <% (estados || []).forEach((estado) => { %>
              <option value="<%= estado %>"><%= estado %></option>
            <% }) %>
          </select>
        </div>

        <div class="contenedor-tabla-pedidos">
          <table class="tabla-pedidos">
            <thead>
              <tr>
                <th>ID Pedido</th>
                <th>Fecha</th>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio Unitario</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th>Acción</th>
              </tr>
            </thead>

            <tbody id="tablaPedidosBody">
              <% if (pedidos && pedidos.length > 0) { %>
                <% pedidos.forEach((pedido) => { %>
                  <tr
                    data-order-id="<%= pedido.orderID %>"
                    data-product-name="<%= pedido.productName %>"
                    data-first-name="<%= pedido.firstName %>"
                    data-last-name="<%= pedido.lastName %>"
                    data-order-status="<%= pedido.orderStatus %>"
                  >
                    <td class="id-pedido"><%= pedido.orderID %></td>
                    <td>
                      <%= new Date(pedido.orderDate).toISOString().split('T')[0] %>
                    </td>
                    <td class="nombre-producto-pedido"><%= pedido.productName %></td>
                    <td><%= pedido.quantity %></td>
                    <td>C$ <%= Number(pedido.unitPrice).toFixed(2) %></td>
                    <td class="nombre-cliente-pedido"><%= pedido.firstName %></td>
                    <td class="apellido-cliente-pedido"><%= pedido.lastName %></td>
                    <td><%= pedido.email %></td>
                    <td><%= pedido.phone %></td>
                    <td>
                      <div class="estado-editable">
                        <select
                          class="select-estado-pedido"
                          data-order-id="<%= pedido.orderID %>"
                          disabled
                        >
                          <% (estados || []).forEach((estado) => { %>
                            <option
                              value="<%= estado %>"
                              <%= pedido.orderStatus === estado ? 'selected' : '' %>
                            >
                              <%= estado %>
                            </option>
                          <% }) %>
                        </select>

                        <button
                          type="button"
                          class="boton-editar-estado"
                          title="Editar estado"
                        >
                          ✎
                        </button>
                      </div>
                    </td>
                    <td>
                      <button
                        type="button"
                        class="boton-guardar-estado hidden"
                        data-order-id="<%= pedido.orderID %>"
                      >
                        Guardar
                      </button>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="11" class="sin-resultados">
                    No hay pedidos registrados.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="pie-tabla-pedidos">
          <p>Mostrando <%= pedidos ? pedidos.length : 0 %> entradas</p>
        </div>
      </section>
    </main>
  </div>

  <script src="/js/sidebar.js"></script>
  <script src="/js/pedidos.js"></script>
</body>
</html>