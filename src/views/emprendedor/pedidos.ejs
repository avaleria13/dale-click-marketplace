<body>
  <div class="layout">
    <%- include('../partials/sidebar', { activePage: 'pedidos' }) %>

    <main class="contenido">
      <%- include('../partials/topbar') %>

      <section class="seccion-pedidos">
        <div class="barra-filtros-pedidos">
          <div class="campo-busqueda-pedido">
            <input
              type="text"
              id="busquedaPedido"
              placeholder="Buscar pedido por ID..."
            />
            <button type="button" class="boton-busqueda-pedido" aria-label="Buscar pedido">
              <img src="/images/buscar.png" alt="Buscar" />
            </button>
          </div>

          <select id="filtroProductoPedido" class="select-filtro-pedido">
            <option value="">Productos</option>
            <option value="Products Picker">Products Picker</option>
            <option value="Consented Eealage">Consented Eealage</option>
            <option value="Voute Breelo">Voute Breelo</option>
            <option value="Products">Products</option>
            <option value="Laie Poduct">Laie Poduct</option>
            <option value="Etaninno de Banas">Etaninno de Banas</option>
          </select>

          <select id="filtroEstadoPedido" class="select-filtro-pedido">
            <option value="">Estado</option>
            <option value="Reservado">Reservado</option>
            <option value="Entregado">Entregado</option>
          </select>
        </div>

