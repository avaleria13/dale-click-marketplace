<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perfil Comercial | Dale Click</title>
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/partials/sidebar.css" />
  <link rel="stylesheet" href="/css/partials/topbar.css" />
  <link rel="stylesheet" href="/css/perfil-comercial.css" />
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar', { activePage: 'perfil' }) %>

    <main class="contenido">
      <!-- <%- include('../partials/topbar', { usuario }) %> -->
      <%- include('../partials/topbar') %>

      <section class="seccion-perfil-comercial">
        <h1 class="titulo-seccion">Información del Negocio</h1>

        <div class="tarjeta-negocio">
          <form id="formPerfilComercial" class="form-perfil-comercial">
            <div class="columna-formulario">
              <div class="fila-campo">
                <label>Nombre del Negocio:</label>
                <input
                  type="text"
                  id="businessName"
                  name="businessName"
                  value="<%= businessProfile?.businessName || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="businessName">✎</button>
              </div>

              <div class="fila-campo">
                <label>Descripción:</label>
                <input
                  type="text"
                  id="description"
                  name="description"
                  value="<%= businessProfile?.description || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="description">✎</button>
              </div>

              <div class="fila-campo">
                <label>Dirección:</label>
                <input
                  type="text"
                  id="addressLine"
                  name="addressLine"
                  value="<%= businessProfile?.addressLine || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="addressLine">✎</button>
              </div>

              <div class="fila-campo">
                <label>Departamento:</label>
                <input
                  type="text"
                  id="department"
                  name="department"
                  value="<%= businessProfile?.department || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="department">✎</button>
              </div>

              <div class="fila-campo">
                <label>Ciudad:</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  value="<%= businessProfile?.city || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="city">✎</button>
              </div>
            </div>

            <div class="columna-formulario">
              <div class="fila-campo">
                <label>Teléfono de Contacto:</label>
                <input
                  type="text"
                  id="contactPhone"
                  name="contactPhone"
                  value="<%= businessProfile?.contactPhone || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="contactPhone">✎</button>
              </div>

              <div class="fila-campo">
                <label>Email de Contacto:</label>
                <input
                  type="email"
                  id="contactEmail"
                  name="contactEmail"
                  value="<%= businessProfile?.contactEmail || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="contactEmail">✎</button>
              </div>

              <div class="fila-campo">
                <label>Logo URL:</label>
                <input
                  type="text"
                  id="logoURL"
                  name="logoURL"
                  value="<%= businessProfile?.logoURL || '' %>"
                  disabled
                />
                <button type="button" class="boton-editar-campo" data-target="logoURL">✎</button>
              </div>

              <div class="preview-logo">
                <% if (businessProfile?.logoURL) { %>
                  <img
                    id="logoPreview"
                    src="<%= businessProfile.logoURL %>"
                    alt="Logo del negocio"
                    onerror="this.style.display='none'"
                  />
                <% } else { %>
                  <img id="logoPreview" src="" alt="Logo del negocio" style="display: none;" />
                <% } %>
              </div>
            </div>

            <div class="acciones-formulario">
              <button type="submit" id="guardarCambios" class="boton-guardar" disabled>Guardar</button>
              <button type="button" id="cancelarCambios" class="boton-cancelar">Cancelar</button>
            </div>
          </form>
        </div>

        <div class="secciones-inferiores">
          <section class="bloque-inferior bloque-horarios">
            <div class="cabecera-bloque">
              <h2>Horarios</h2>
              <button type="button" class="boton-secundario" id="btnAbrirModalHorarios">✎ Editar Horario</button>
            </div>

            <div class="contenedor-horarios">
              <table class="tabla-horarios">
                <tbody>
                  <% if (businessHours && businessHours.length > 0) { %>
                    <% businessHours.forEach((hour) => { %>
                      <tr>
                        <td><%= hour.dayOfWeek %></td>
                        <td>
                          <% if (hour.isClosed) { %>
                            Cerrado
                          <% } else { %>
                            <%= String(hour.openTime || '').slice(0, 5) %> - <%= String(hour.closeTime || '').slice(0, 5) %>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="2" class="sin-resultados">No hay horarios registrados.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </section>

          <section class="bloque-inferior bloque-suscripciones">
            <h2>Suscripciones</h2>

            <div class="contenido-suscripcion">
              <p>
                <strong>Plan Actual:</strong>
                <span class="texto-plan"><%= subscription?.planName || 'Sin plan activo' %></span>
              </p>

              <p>
                <strong>Fecha de Inicio:</strong>
                <%= subscription?.startDate ? new Date(subscription.startDate).toISOString().split('T')[0] : 'N/D' %>
              </p>

              <p>
                <strong>Fecha de Fin:</strong>
                <%= subscription?.endDate ? new Date(subscription.endDate).toISOString().split('T')[0] : 'N/D' %>
              </p>

              <p>
                <strong>Anuncios Destacados:</strong>
                <%= subscription?.featuredAds ?? 0 %>
              </p>

              <div class="barra-progreso">
                <div class="progreso-actual"></div>
              </div>
            </div>
          </section>
        </div>
      </section>
    </main>
  </div>

  <div class="modal-overlay hidden" id="modalHorariosOverlay">
    <div class="modal-contenido modal-horarios">
      <div class="modal-header">
        <h2>Editar Horarios</h2>
        <button type="button" class="modal-cerrar" data-close-modal="modalHorariosOverlay">×</button>
      </div>

      <form id="formHorarios" class="form-modal">
        <% if (businessHours && businessHours.length > 0) { %>
          <% businessHours.forEach((hour, index) => { %>
            <div
              class="fila-horario"
              data-day="<%= hour.dayOfWeek %>"
            >
              <div class="dia-horario"><%= hour.dayOfWeek %></div>

              <label class="check-cerrado">
                <input
                  type="checkbox"
                  class="input-cerrado"
                  <%= hour.isClosed ? 'checked' : '' %>
                />
                Cerrado
              </label>

              <input
                type="time"
                class="input-hora-apertura"
                value="<%= hour.isClosed ? '' : String(hour.openTime || '').slice(0, 5) %>"
                <%= hour.isClosed ? 'disabled' : '' %>
              />

              <input
                type="time"
                class="input-hora-cierre"
                value="<%= hour.isClosed ? '' : String(hour.closeTime || '').slice(0, 5) %>"
                <%= hour.isClosed ? 'disabled' : '' %>
              />
            </div>
          <% }) %>
        <% } %>

        <div class="modal-acciones">
          <button type="button" class="boton-secundario" data-close-modal="modalHorariosOverlay">Cancelar</button>
          <button type="submit" class="boton-primario">Guardar horarios</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/sidebar.js"></script>
  <script src="/js/perfil-comercial.js"></script>
</body>
</html>