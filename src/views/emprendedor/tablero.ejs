<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tablero | Dale Click</title>
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/sidebar.css" />
  <link rel="stylesheet" href="/css/tablero.css" />
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-top">
        <div class="logo-container">
          <img src="/images/logo_daleclick.png" alt="Logo Dale Click" class="logo" />
        </div>

        <nav class="menu-lateral">
          <a href="/" class="menu-item activo">
            <img class="icono-menu" src="/images/tablero.png" alt="Tablero" />
            <span>Tablero</span>
          </a>

          <a href="/productos" class="menu-item">
            <img class="icono-menu" src="/images/productos.png" alt="Productos" />
            <span>Productos</span>
          </a>

          <a href="/pedidos" class="menu-item">
            <img class="icono-menu" src="/images/pedidos.png" alt="Pedidos" />
            <span>Pedidos</span>
          </a>

          <a href="/perfil-comercial" class="menu-item">
            <img class="icono-menu" src="/images/perfil-comercial.png" alt="Perfil comercial" />
            <span>Perfil Comercial</span>
          </a>

          <a href="/clientes" class="menu-item">
            <img class="icono-menu" src="/images/clientes.png" alt="Clientes" />
            <span>Clientes</span>
          </a>

          <a href="/ventas" class="menu-item">
            <img class="icono-menu" src="/images/ventas.png" alt="Ventas" />
            <span>Ventas</span>
          </a>
        </nav>
      </div>

      <div class="sidebar-footer">
        <a href="#" class="menu-item">
          <img class="icono-menu" src="/images/configuracion.png" alt="Configuración" />
          <span>Configuración</span>
        </a>

        <a href="#" class="menu-item cerrar-sesion">
          <img class="icono-menu" src="/images/cerrar-sesion.png" alt="Cerrar sesión" />
          <span>Cerrar sesión</span>
        </a>
      </div>
    </aside>

    <main class="contenido">
      <header class="barra-superior">
        <div class="barra-izquierda">
          <button class="boton-menu" type="button" aria-label="Abrir menú">
            ☰
          </button>
        </div>

        <div class="barra-derecha">
          <button class="icono-superior" type="button" aria-label="Buscar"> <img src="/images/buscar.png" alt="Buscar"> </button>
          <button class="icono-superior" type="button" aria-label="Aplicaciones"> <img src="/images/apps.png" alt="Aplicaciones"> </button>
          <button class="icono-superior" type="button" aria-label="Notificaciones"> <img src="/images/notificaciones.png" alt="Notificaciones"></button>
          <img src="/images/perfil-usuario.png" alt="Perfil de usuario" class="avatar-usuario" />
        </div>
      </header>

      <header class="encabezado">
        <h1>¡Bienvenida de nuevo, Gabriela!</h1>
        <p>Resumen del tablero</p>
      </header>

      <section class="tarjetas-resumen">
        <article class="tarjeta">
          <h2>Productos totales</h2>
          <p class="numero">28</p>
          <span>Conteo de categorías y tipos de productos</span>
        </article>

        <article class="tarjeta">
          <h2>Órdenes crecientes</h2>
          <p class="numero">55</p>
          <span>Pedidos recientes del negocio</span>
        </article>

        <article class="tarjeta">
          <h2>Estadísticas</h2>
          <p class="numero">C$ 9225.00</p>
          <span>Ventas netas</span>
        </article>
      </section>
    </main>
  </div>

  <script src="/js/sidebar.js"></script>
  <script src="/js/tablero.js"></script>
</body>
</html>